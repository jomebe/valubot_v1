# Discord Bot Configuration
DISCORD_TOKEN=your_discord_bot_token_here

# VALORANT API Config (e.g., HenrikDev API)
VALORANT_API_KEY=your_henrikdev_api_key_here

# Session Security Configuration
# Encryption key used to encrypt Riot authentication tokens. Must be a secure random string.
ENCRYPTION_KEY=your_secret_encryption_key_here

# Firebase Configuration (Optional)
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=
FIREBASE_MEASUREMENT_ID=

# Voice Configuration
VOICE_CYCLE_ROLE_ID=
RENDER_EXTERNAL_URL=
PORT=10000
